---
import { getGuideUrl, getCategoryUrl, slugifyCategory } from "../lib/routes.js";

const { guide } = Astro.props;
const categorySlug = slugifyCategory(guide.category || "General");
---

<article class="guide-card">
  <p class="eyebrow">
    <a href={getCategoryUrl(categorySlug)}>{guide.category || "General"}</a>
  </p>
  <h3><a href={getGuideUrl(guide.slug)}>{guide.title}</a></h3>
  <p class="description">{guide.description}</p>
  <div class="actions">
    <a class="primary-link" href={getGuideUrl(guide.slug)}>Read guide</a>
  </div>
</article>

<style>
  .guide-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 18px;
    padding: 24px;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.04);
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .eyebrow {
    margin: 0 0 10px;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #2563eb;
  }

  .eyebrow a {
    color: #2563eb;
    text-decoration: none;
  }

  .eyebrow a:hover {
    text-decoration: underline;
  }

  h3 {
    margin: 0 0 12px;
    font-size: 1.35rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  h3 a {
    color: #0f172a;
    text-decoration: none;
  }

  h3 a:hover {
    color: #2563eb;
  }

  .description {
    margin: 0;
    color: #475569;
    line-height: 1.7;
    flex-grow: 1;
  }

  .actions {
    margin-top: 18px;
  }

  .primary-link {
    color: #2563eb;
    text-decoration: none;
    font-weight: 800;
  }

  .primary-link:hover {
    text-decoration: underline;
  }
</style>
