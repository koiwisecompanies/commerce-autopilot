---
const navItems = [
  { label: "Home", href: "/" },
  { label: "Guides", href: "/#featured-guides" },
  { label: "Categories", href: "/#categories" }
];
---

<header class="site-header">
  <div class="inner">
    <a class="brand" href="/">
      <span class="brand-mark">SP</span>
      <span>Smart Product Picks</span>
    </a>

    <nav aria-label="Primary navigation">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(248, 250, 252, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #e2e8f0;
  }

  .inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: #0f172a;
    text-decoration: none;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .brand-mark {
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #2563eb, #0f172a);
    color: #fff;
    border-radius: 12px;
    font-size: 0.9rem;
    box-shadow: 0 10px 24px rgba(37, 99, 235, 0.18);
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .nav-list a {
    text-decoration: none;
    color: #475569;
    font-weight: 600;
  }

  .nav-list a:hover {
    color: #0f172a;
  }

  @media (max-width: 720px) {
    .inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
