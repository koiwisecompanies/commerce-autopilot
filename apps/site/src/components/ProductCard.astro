---
const { title, description, link } = Astro.props;
---

<div class="product-card">
  <h3>{title}</h3>
  <p>{description}</p>
  <a class="btn" href={link}>View Deal</a>
</div>

<style>
.product-card {
  border: 1px solid #e5e7eb;
  padding: 20px;
  border-radius: 10px;
  background: white;
}

.product-card h3 {
  margin-bottom: 10px;
}

.btn {
  display: inline-block;
  margin-top: 10px;
  background: #2563eb;
  color: white;
  padding: 8px 14px;
  border-radius: 6px;
  text-decoration: none;
}
</style>
