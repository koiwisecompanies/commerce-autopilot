---
import BaseLayout from "./BaseLayout.astro";
import guides from "../data/guides.json";

const {
  title,
  description,
  intro,
  products = [],
  buyingGuide,
  faqQuestion,
  faqAnswer,
  category = "Guide"
} = Astro.props;

const relatedGuides = guides
  .filter((guide) => guide.title !== title)
  .slice(0, 3);
---

<BaseLayout title={title} description={description}>
  <main class="container">
    <section class="guide-hero">
      <div class="guide-copy">
        <p class="eyebrow">{category}</p>
        <h1>{title}</h1>
        <p class="lead">{intro}</p>
      </div>

      <aside class="hero-side panel">
        <h2>Quick Take</h2>
        <p>
          This guide highlights top options, key buying factors, and a short FAQ so visitors can move from search to decision faster.
        </p>
      </aside>
    </section>

    <section class="guide-section">
      <div class="section-header">
        <h2 class="section-title">Top Picks</h2>
        <p class="section-copy">These are the main products featured in this guide.</p>
      </div>

      <div class="grid grid-3">
        {products.map((product, index) => (
          <article class="product-panel panel">
            <p class="eyebrow">Pick #{index + 1}</p>
            <h3>{product.title}</h3>
            <p>{product.description}</p>
            <a class="deal-btn" href={product.link}>View Deal</a>
          </article>
        ))}
      </div>
    </section>

    <section class="content-grid">
      <article class="panel content-panel">
        <h2>Buying Guide</h2>
        <p>{buyingGuide}</p>
      </article>

      <article class="panel content-panel">
        <h2>Frequently Asked Questions</h2>
        <h3>{faqQuestion}</h3>
        <p>{faqAnswer}</p>
      </article>
    </section>

    <section class="guide-section">
      <div class="section-header">
        <h2 class="section-title">Related Guides</h2>
        <p class="section-copy">Keep visitors moving deeper into the site with adjacent buying-intent pages.</p>
      </div>

      <div class="grid grid-3">
        {relatedGuides.map((guide) => (
          <article class="related-card panel">
            <p class="eyebrow">{guide.category}</p>
            <h3>{guide.title}</h3>
            <p>{guide.description}</p>
            <a class="text-link" href={`/guides/${guide.slug}`}>Read guide</a>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .guide-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.8fr) minmax(280px, 0.9fr);
    gap: 24px;
    align-items: start;
  }

  .guide-copy h1 {
    margin: 0 0 16px;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .lead {
    margin: 0;
    max-width: 760px;
    color: #475569;
    line-height: 1.75;
    font-size: 1.08rem;
  }

  .hero-side h2,
  .content-panel h2,
  .product-panel h3,
  .related-card h3 {
    margin-top: 0;
  }

  .hero-side p,
  .content-panel p,
  .product-panel p,
  .related-card p {
    color: #475569;
    line-height: 1.75;
  }

  .guide-section {
    margin-top: 42px;
  }

  .section-header {
    margin-bottom: 20px;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-top: 42px;
  }

  .deal-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 18px;
    background: #2563eb;
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    padding: 10px 16px;
    border-radius: 10px;
  }

  .deal-btn:hover {
    background: #1d4ed8;
  }

  @media (max-width: 900px) {
    .guide-hero,
    .content-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
