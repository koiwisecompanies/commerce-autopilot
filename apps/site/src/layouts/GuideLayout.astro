---
const {
  title,
  description,
  intro,
  products = [],
  buyingGuide,
  faqQuestion,
  faqAnswer
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <main class="container">
      <header class="hero">
        <p class="eyebrow">Smart Product Picks</p>
        <h1>{title}</h1>
        <p class="intro">{intro}</p>
      </header>

      <section class="section">
        <h2>Top Picks</h2>
        <div class="grid">
          {products.map((product) => (
            <article class="card">
              <h3>{product.title}</h3>
              <p>{product.description}</p>
              <a class="btn" href={product.link}>View Deal</a>
            </article>
          ))}
        </div>
      </section>

      <section class="section content-box">
        <h2>Buying Guide</h2>
        <p>{buyingGuide}</p>
      </section>

      <section class="section content-box">
        <h2>Frequently Asked Questions</h2>
        <h3>{faqQuestion}</h3>
        <p>{faqAnswer}</p>
      </section>

      <section class="section related">
        <h2>Related Guides</h2>
        <ul>
          <li><a href="/guides/best-portable-blender">Best Portable Blender for Protein Shakes</a></li>
          <li><a href="/">Back to Homepage</a></li>
        </ul>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f8fafc;
    --text: #0f172a;
    --muted: #475569;
    --card: #ffffff;
    --border: #e2e8f0;
    --primary: #2563eb;
    --primary-hover: #1d4ed8;
  }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--text);
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 48px 20px 72px;
  }

  .hero {
    margin-bottom: 36px;
  }

  .eyebrow {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.1;
    margin: 0 0 16px;
  }

  .intro {
    max-width: 760px;
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .section {
    margin-top: 42px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin-top: 18px;
  }

  .card,
  .content-box,
  .related {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
  }

  .card h3 {
    margin-top: 0;
    margin-bottom: 12px;
    font-size: 1.3rem;
  }

  .card p,
  .content-box p,
  .related li {
    color: var(--muted);
    line-height: 1.7;
  }

  .btn {
    display: inline-block;
    margin-top: 14px;
    background: var(--primary);
    color: white;
    text-decoration: none;
    padding: 10px 16px;
    border-radius: 10px;
    font-weight: 700;
  }

  .btn:hover {
    background: var(--primary-hover);
  }

  h2 {
    font-size: 1.7rem;
    margin-bottom: 14px;
  }

  h3 {
    margin-bottom: 10px;
  }

  .related ul {
    padding-left: 18px;
    margin: 0;
  }

  .related a {
    color: var(--primary);
    text-decoration: none;
  }

  .related a:hover {
    text-decoration: underline;
  }
</style>
