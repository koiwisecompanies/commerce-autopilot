---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import GuideCard from "../components/GuideCard.astro";
import { getRelatedGuides } from "../lib/guides.js";
import { getGuideUrl, getCategoryUrl, slugifyCategory, getOutboundUrl } from "../lib/routes.js";

const {
  slug,
  title,
  description,
  intro,
  products = [],
  buyingGuide,
  faqQuestion,
  faqAnswer,
  category = "Guide"
} = Astro.props;

const relatedGuides = getRelatedGuides({ slug, title, category }, 3);
const categorySlug = slugifyCategory(category);

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Guides", href: "/guides" },
  { label: category, href: getCategoryUrl(categorySlug) },
  { label: title, href: getGuideUrl(slug) }
];

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": faqQuestion,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faqAnswer
      }
    }
  ]
};

const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    "item": `http://localhost:4321${item.href}`
  }))
};
---

<BaseLayout title={title} description={description} path={getGuideUrl(slug)} type="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbStructuredData)} />
  </Fragment>

  <main class="container">
    <Breadcrumbs items={breadcrumbItems} />

    <section class="guide-hero">
      <div class="guide-copy">
        <p class="eyebrow">{category}</p>
        <h1>{title}</h1>
        <p class="lead">{intro}</p>
      </div>

      <aside class="hero-side panel">
        <h2>Quick Take</h2>
        <p>
          This guide highlights top options, key buying factors, and adjacent pages so users can move from search to decision quickly.
        </p>
        <a class="text-link" href="/guides">Browse all guides</a>
      </aside>
    </section>

    <section class="guide-section">
      <div class="section-header">
        <h2 class="section-title">Top Picks</h2>
        <p class="section-copy">These are the main products featured in this guide.</p>
      </div>

      <div class="grid grid-3">
        {products.map((product, index) => (
          <article class="product-panel panel">
            <p class="eyebrow">Pick #{index + 1}</p>
            <h3>{product.title}</h3>
            <p>{product.description}</p>
            <a class="deal-btn" href={getOutboundUrl("merchant", `${slug}-product-${index + 1}`)}>View Deal</a>
          </article>
        ))}
      </div>
    </section>

    <section class="content-grid">
      <article class="panel content-panel">
        <h2>Buying Guide</h2>
        <p>{buyingGuide}</p>
      </article>

      <article class="panel content-panel">
        <h2>Frequently Asked Questions</h2>
        <h3>{faqQuestion}</h3>
        <p>{faqAnswer}</p>
      </article>
    </section>

    <section class="guide-section">
      <div class="section-header">
        <h2 class="section-title">Explore More in {category}</h2>
        <p class="section-copy">Keep authority and user flow moving with related pages.</p>
      </div>

      <div class="grid grid-3">
        {relatedGuides.map((guide) => (
          <GuideCard guide={guide} />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .guide-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.8fr) minmax(280px, 0.9fr);
    gap: 24px;
    align-items: start;
  }

  .guide-copy h1 {
    margin: 0 0 16px;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .lead {
    margin: 0;
    max-width: 760px;
    color: #475569;
    line-height: 1.75;
    font-size: 1.08rem;
  }

  .hero-side h2,
  .content-panel h2,
  .product-panel h3 {
    margin-top: 0;
  }

  .hero-side p,
  .content-panel p,
  .product-panel p {
    color: #475569;
    line-height: 1.75;
  }

  .guide-section {
    margin-top: 42px;
  }

  .section-header {
    margin-bottom: 20px;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-top: 42px;
  }

  .deal-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 18px;
    background: #2563eb;
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    padding: 10px 16px;
    border-radius: 10px;
  }

  .deal-btn:hover {
    background: #1d4ed8;
  }

  @media (max-width: 900px) {
    .guide-hero,
    .content-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
