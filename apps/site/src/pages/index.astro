---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import guides from "../data/guides.json";

const featuredGuides = guides.filter((guide) => guide.featured).slice(0, 3);

const categories = Array.from(new Set(guides.map((guide) => guide.category)))
  .map((category) => ({
    name: category,
    count: guides.filter((guide) => guide.category === category).length
  }))
  .sort((a, b) => a.name.localeCompare(b.name));

const latestGuides = [...guides].slice(-3).reverse();
---

<BaseLayout
  title="Smart Product Picks | Buyer-Intent Product Guides"
  description="Explore fast, trustworthy product guides built to help shoppers compare options and choose the right products."
>
  <main class="container">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Affiliate SEO Foundation</p>
        <h1>Find Better Products Faster</h1>
        <p class="hero-text">
          Smart Product Picks turns buyer-intent topics into fast, clear, conversion-ready guides. Browse featured picks, categories, and newly generated pages.
        </p>

        <div class="hero-actions">
          <a class="primary-btn" href="#featured-guides">Explore Featured Guides</a>
          <a class="secondary-btn" href="#categories">Browse Categories</a>
        </div>

        <div class="hero-metrics">
          <div class="metric panel">
            <strong>{guides.length}</strong>
            <span>Live Guides</span>
          </div>
          <div class="metric panel">
            <strong>{categories.length}</strong>
            <span>Categories</span>
          </div>
          <div class="metric panel">
            <strong>Fast</strong>
            <span>Static SEO Pages</span>
          </div>
        </div>
      </div>

      <aside class="hero-panel panel">
        <h2>How this site is built</h2>
        <ul>
          <li>Guide pages are rendered from structured data.</li>
          <li>Reusable templates keep pages consistent and scalable.</li>
          <li>The generator can create new topics without hand-coding each page.</li>
        </ul>
      </aside>
    </section>

    <section id="featured-guides" class="homepage-section">
      <div class="section-header">
        <p class="eyebrow">Featured</p>
        <h2 class="section-title">Top Money-Page Templates</h2>
        <p class="section-copy">
          These are the featured buying guides currently highlighted on the homepage.
        </p>
      </div>

      <div class="grid grid-3">
        {featuredGuides.map((guide) => (
          <ProductCard
            title={guide.title}
            description={guide.description}
            link={`/guides/${guide.slug}`}
            eyebrow={guide.category}
          />
        ))}
      </div>
    </section>

    <section id="categories" class="homepage-section">
      <div class="section-header">
        <p class="eyebrow">Categories</p>
        <h2 class="section-title">Guide Categories</h2>
        <p class="section-copy">
          Lightweight taxonomy now, category pages later. This prepares the site for bigger SEO scaling.
        </p>
      </div>

      <div class="grid grid-3">
        {categories.map((category) => (
          <article class="panel category-card">
            <h3>{category.name}</h3>
            <p>{category.count} guide{category.count === 1 ? "" : "s"} currently mapped to this category.</p>
          </article>
        ))}
      </div>
    </section>

    <section class="homepage-section">
      <div class="section-header">
        <p class="eyebrow">Trust Layer</p>
        <h2 class="section-title">How We Structure Buying Guides</h2>
        <p class="section-copy">
          Every guide is designed to move a shopper from search to decision with a consistent content structure.
        </p>
      </div>

      <div class="grid trust-grid">
        <article class="panel">
          <h3>Focused topics</h3>
          <p>Each guide targets a specific buyer-intent angle instead of trying to rank for everything at once.</p>
        </article>

        <article class="panel">
          <h3>Clear sections</h3>
          <p>Top picks, buying guidance, FAQs, and related links keep the pages useful and easy to scan.</p>
        </article>

        <article class="panel">
          <h3>Generator-ready</h3>
          <p>The structure is built so future automation can create many guides without breaking consistency.</p>
        </article>
      </div>
    </section>

    <section class="homepage-section">
      <div class="section-header">
        <p class="eyebrow">Latest</p>
        <h2 class="section-title">Recently Added Guides</h2>
        <p class="section-copy">
          These are the newest entries currently in your guide data.
        </p>
      </div>

      <div class="grid grid-3">
        {latestGuides.map((guide) => (
          <article class="panel latest-card">
            <p class="eyebrow">{guide.category}</p>
            <h3>{guide.title}</h3>
            <p>{guide.description}</p>
            <a class="text-link" href={`/guides/${guide.slug}`}>Read guide</a>
          </article>
        ))}
      </div>
    </section>

    <section class="homepage-section cta-section">
      <div class="panel cta-panel">
        <p class="eyebrow">Next Stage</p>
        <h2>Ready for Large-Scale SEO Generation</h2>
        <p>
          This frontend foundation is now strong enough to support larger content batches, automation, and future controller-driven publishing.
        </p>
        <a class="primary-btn" href="/guides/best-budget-office-chair">View a generated guide</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr);
    gap: 24px;
    align-items: stretch;
  }

  .hero-copy h1 {
    margin: 0 0 16px;
    font-size: clamp(2.5rem, 5vw, 4.4rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .hero-text {
    margin: 0;
    max-width: 760px;
    color: #475569;
    line-height: 1.8;
    font-size: 1.08rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 24px;
  }

  .primary-btn,
  .secondary-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    padding: 12px 18px;
    text-decoration: none;
    font-weight: 800;
  }

  .primary-btn {
    background: #2563eb;
    color: #ffffff;
  }

  .primary-btn:hover {
    background: #1d4ed8;
  }

  .secondary-btn {
    background: #ffffff;
    color: #0f172a;
    border: 1px solid #cbd5e1;
  }

  .secondary-btn:hover {
    border-color: #94a3b8;
  }

  .hero-panel h2 {
    margin-top: 0;
    margin-bottom: 16px;
  }

  .hero-panel ul {
    margin: 0;
    padding-left: 18px;
    color: #475569;
    line-height: 1.8;
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-top: 28px;
  }

  .metric {
    padding: 18px 20px;
  }

  .metric strong {
    display: block;
    font-size: 1.6rem;
    color: #0f172a;
    margin-bottom: 6px;
  }

  .metric span {
    color: #64748b;
    font-weight: 600;
  }

  .homepage-section {
    margin-top: 56px;
  }

  .section-header {
    margin-bottom: 22px;
  }

  .category-card h3,
  .latest-card h3,
  .cta-panel h2 {
    margin-top: 0;
  }

  .category-card p,
  .latest-card p,
  .cta-panel p {
    color: #475569;
    line-height: 1.75;
  }

  .trust-grid {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .cta-section {
    margin-bottom: 12px;
  }

  .cta-panel {
    text-align: left;
    background: linear-gradient(180deg, #ffffff 0%, #eff6ff 100%);
  }

  @media (max-width: 920px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero-metrics {
      grid-template-columns: 1fr;
    }
  }
</style>
