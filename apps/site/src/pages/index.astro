---
import BaseLayout from "../layouts/BaseLayout.astro";
import GuideCard from "../components/GuideCard.astro";
import CategoryCard from "../components/CategoryCard.astro";
import { getFeaturedGuides, getLatestGuides } from "../lib/guides.js";
import { getAllCategories } from "../lib/categories.js";

const featuredGuides = getFeaturedGuides(3);
const latestGuides = getLatestGuides(6);
const categories = getAllCategories();

const websiteStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Smart Product Picks",
  "url": "http://localhost:4321/"
};
---

<BaseLayout
  title="Smart Product Picks"
  description="Explore buyer-intent product guides, category hubs, and a stronger publishing structure built for SEO growth."
  path="/"
  type="website"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteStructuredData)} />
  </Fragment>

  <main class="container">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Publishing Architecture</p>
        <h1>Buyer-Intent Product Guides Built to Scale</h1>
        <p class="hero-text">
          Smart Product Picks is now structured as a real publishing system with guide pages, category hubs, internal links, and data-driven content flow.
        </p>

        <div class="hero-actions">
          <a class="primary-btn" href="/guides">Browse All Guides</a>
          <a class="secondary-btn" href="/categories/electronics">Explore Categories</a>
        </div>
      </div>

      <aside class="hero-panel panel">
        <h2>What this batch added</h2>
        <ul>
          <li>Guides index</li>
          <li>Category pages</li>
          <li>Breadcrumbs</li>
          <li>Related guides</li>
          <li>SEO metadata system</li>
          <li>Sitemap and robots routes</li>
        </ul>
      </aside>
    </section>

    <section class="homepage-section">
      <div class="section-header">
        <p class="eyebrow">Featured</p>
        <h2 class="section-title">Featured Guides</h2>
        <p class="section-copy">Top buyer-intent pages highlighted for stronger discovery and homepage authority flow.</p>
      </div>

      <div class="grid grid-3">
        {featuredGuides.map((guide) => (
          <GuideCard guide={guide} />
        ))}
      </div>
    </section>

    <section class="homepage-section">
      <div class="section-header">
        <p class="eyebrow">Categories</p>
        <h2 class="section-title">Category Hubs</h2>
        <p class="section-copy">Each category now has a dedicated browse page to support crawlability and topical clustering.</p>
      </div>

      <div class="grid grid-3">
        {categories.map((category) => (
          <CategoryCard category={category} />
        ))}
      </div>
    </section>

    <section class="homepage-section">
      <div class="section-header">
        <p class="eyebrow">Latest</p>
        <h2 class="section-title">Latest Guides</h2>
        <p class="section-copy">Recently generated pages are surfaced here to improve discovery and keep the homepage fresh.</p>
      </div>

      <div class="grid grid-3">
        {latestGuides.map((guide) => (
          <GuideCard guide={guide} />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr);
    gap: 24px;
    align-items: stretch;
  }

  .hero-copy h1 {
    margin: 0 0 16px;
    font-size: clamp(2.5rem, 5vw, 4.4rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .hero-text {
    margin: 0;
    max-width: 760px;
    color: #475569;
    line-height: 1.8;
    font-size: 1.08rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 24px;
  }

  .primary-btn,
  .secondary-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    padding: 12px 18px;
    text-decoration: none;
    font-weight: 800;
  }

  .primary-btn {
    background: #2563eb;
    color: #ffffff;
  }

  .primary-btn:hover {
    background: #1d4ed8;
  }

  .secondary-btn {
    background: #ffffff;
    color: #0f172a;
    border: 1px solid #cbd5e1;
  }

  .secondary-btn:hover {
    border-color: #94a3b8;
  }

  .hero-panel h2 {
    margin-top: 0;
  }

  .hero-panel ul {
    margin: 0;
    padding-left: 18px;
    color: #475569;
    line-height: 1.8;
  }

  .homepage-section {
    margin-top: 56px;
  }

  .section-header {
    margin-bottom: 22px;
  }

  @media (max-width: 920px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }
</style>
